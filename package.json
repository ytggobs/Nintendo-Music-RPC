{
  "name": "nintendo-music-rpc-bridge",
  "version": "1.1.1",
  "description": "Electron bridge for Nintendo Music Discord Rich Presence.",
  "author": "Ben Lawrence",
  "desktopName": "nintendo-music-rpc.desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bentheminernz/Nintendo-Music-RPC.git"
  },
  "main": "app/dist/main.js",
  "scripts": {
    "embed-html": "node app/scripts/embed-html.mjs",
    "copy-assets": "node -e \"const fs=require('fs');fs.cpSync('app/assets','app/dist/assets',{recursive:true})\"",
    "build": "npm run embed-html && tsc && npm run copy-assets",
    "watch": "tsc --watch",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "nz.benlawrence.nintendo-music-rpc-bridge",
    "productName": "Nintendo Music RPC",
    "copyright": "Copyright © 2026 Ben Lawrence",
    "extraResources": [
      {
        "from": "app/dist/preload-prefs.js",
        "to": "app/dist/preload-prefs.js"
      }
    ],
    "mac": {
      "identity": null,
      "icon": "app/assets/icon.icns",
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    },
    "win": {
      "icon": "extension/icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "extension/icons/icon.png",
      "category": "AudioVideo",
      "syncDesktopName": true,
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release",
      "owner": "Bentheminernz",
      "repo": "Nintendo-Music-RPC",
      "private": false
    }
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}