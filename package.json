{
  "name": "nintendo-music-rpc-bridge",
  "version": "0.3.0",
  "description": "Electron bridge for Nintendo Music Discord Rich Presence.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bentheminernz/Nintendo-Music-RPC.git"
  },
  "main": "app/dist/main.js",
  "scripts": {
    "copy-assets": "node -e \"const fs=require('fs');fs.cpSync('app/assets','app/dist/assets',{recursive:true});fs.copyFileSync('app/preferences.html','app/dist/preferences.html')\"",
    "build": "tsc && npm run copy-assets",
    "watch": "tsc --watch",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "nz.benlawrence.nintendo-music-rpc-bridge",
    "productName": "Nintendo Music RPC",
    "copyright": "Copyright © 2026 Ben Lawrence",
    "mac": {
      "identity": null,
      "icon": "app/assets/icon.icns",
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    },
    "win": {
      "icon": "extension/icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "extension/icons/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}
