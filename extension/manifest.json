{
  "manifest_version": 3,
  "name": "Nintendo Music Discord RPC",
  "version": "1.0.1",
  "description": "Logs Nintendo Music tracks to Discord Rich Presence.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://music.nintendo.com/*",
    "http://127.0.0.1:17891/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nintendo Music RPC",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nintendo-music-logger@benlawrence.nz",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://music.nintendo.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}